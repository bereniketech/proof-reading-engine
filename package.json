{
  "name": "proof-reading-engine",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "npm run typecheck --prefix frontend",
    "typecheck:backend": "npm run typecheck --prefix backend",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm run lint --prefix frontend",
    "lint:backend": "npm run lint --prefix backend",
    "lint:fix": "npm run lint:fix:frontend && npm run lint:fix:backend",
    "lint:fix:frontend": "npm run lint:fix --prefix frontend",
    "lint:fix:backend": "npm run lint:fix --prefix backend",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test:e2e": "dotenv -e .env -- playwright test",
    "build": "npm run --workspace backend build"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
